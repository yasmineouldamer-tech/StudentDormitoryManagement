          <property name="styleSheet">
           <string notr="true">QLineEdit {
    /* Set typed text size to a clean, readable 12pt */
    font: 350 12pt &quot;Segoe UI&quot;;
    color: #0f2446; 
    background-color: rgb(255, 255, 255);
    
    /* Modern structural borders */
    border: 1px solid #ccc;
    border-radius: 8px;
    
    /* Spacing: 50px left for padlock, 45px right to leave room for the eye button */
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 50px; 
    padding-right: 45px; 

    /* LEFT SIDE: Padlock Icon */
    background-image: url(:/images/.qtcreator/padlock.png);
    background-repeat: no-repeat;
    background-position: left center;
}

/* Styled proportionally right below the main font size */
QLineEdit::placeholder {
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 11pt; 
    font-weight: 350;
    color: #a0aec0; 
}

/* UNIVERSAL FIX FOR THE RIGHT SIDE ICON */
