          <property name="styleSheet">
           <string notr="true">QLineEdit {
    /* Balance text dimensions nicely */
    font: 350 12pt &quot;Segoe UI&quot;;
    color: #0f2446; 
    background-color: rgb(255, 255, 255);
    
    border: 1px solid #ccc;
    border-radius: 8px;
    
    /* Strict padding structure to leave clean space for your icons */
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 50px; 
    padding-right: 12px;

    /* Icon Path Definition */
    background-image: url(:/images/.qtcreator/user.png);
    background-repeat: no-repeat;
    background-position: left center;
}

QLineEdit::placeholder {
    /* Separate rule explicitly handling empty state hint text rendering */
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 11pt; 
    font-weight: 350;
    color: #a0aec0; 
}</string>
          </property>
