             <property name="styleSheet">
              <string notr="true">QTableWidget {
    background-color: white;
    border: 1px solid #dcdcdc;
    border-radius: 10px;
    gridline-color: #e5e5e5;
    font-size: 14pt;
}
/* 1. Style the parent header container to remove ugly native margins/borders */
QHeaderView {
    background-color: #000050; /* Forces the whole background bar to be blue */
    border: none;
    margin: 0px;
    padding: 0px;
}

/* 2. Update your section style so it matches perfectly */
QHeaderView::section {
    background-color: #000050; 
    color: #ffffff !important;  
    font-weight: bold;
    font-size: 20px;
    qproperty-alignment: 'AlignCenter'; 
    border: none;
    /* Add a clean, very subtle line between columns so they don't blend blindly */
    border-right: 1px solid #12126a; 
    padding: 0px;
}

/* 3. Remove any gaps at the very top left/right corner of the table */
QTableWidget QTableCornerButton::section {
    background-color: #000050;
    border: none;
}</string>
